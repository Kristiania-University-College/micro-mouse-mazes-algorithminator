ocm(BBDirection.REVERSE, 60, 24)\n    # bitbot.spin_deg(BBRobotDirection.LEFT, 60, 90)\n    #for index4 in range(7):\n    #    look = look_left(look)\n    #    bitbot.gocm(BBDirection.REVERSE, 60, 24)\nbasic.forever(on_forever)\n","pxt.json":"{\n    \"name\": \"bitbot pro - Copy\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"BitBot\": \"github:4tronix/bitbot#v2.1.13\",\n        \"servo\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\"\n}\n"}},{"timestamp":1774165992861,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"55\" y=\"49\"><statement name=\"HANDLER\"><block type=\"BBPidEnable\"><value name=\"enable\"><shadow type=\"toggleOnOff\"><field name=\"on\">false</field></shadow></value></block></statement></block><block type=\"device_forever\" x=\"31\" y=\"279\"><statement name=\"HANDLER\"><block type=\"BBSteer\"><value name=\"direction\"><shadow type=\"math_number_minmax\"><mutation min=\"-100\" max=\"100\" label=\"Direction\" precision=\"0\"></mutation><field name=\"SLIDER\">0</field></shadow><block type=\"BBMergeLine\"></block></value><value name=\"speed\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"100\" label=\"Speed\" precision=\"0\"></mutation><field name=\"SLIDER\">30</field></shadow></value><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">100</field></shadow></value></block></next></block></statement></block></xml>","main.ts":"","README.md":"","main.py":"bitbot.enable_pid(False)\nleftSensor = 1023\nrightSensor = 1023\ncenterSensor = 1023\n\ndef on_forever():\n    global rightSensor, leftSensor, centerSensor\n        \n    rightSensor = bitbot.read_line_a